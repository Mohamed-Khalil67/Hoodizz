# Frontend Firebase config (Angular reads these at build time via @ngx-env/builder)
# Get these from Firebase Console > Project Settings > Web App
NG_APP_FIREBASE_API_KEY=
NG_APP_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NG_APP_FIREBASE_PROJECT_ID=your-project
NG_APP_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NG_APP_FIREBASE_MESSAGING_SENDER_ID=
NG_APP_FIREBASE_APP_ID=
NG_APP_FIREBASE_MEASUREMENT_ID=
